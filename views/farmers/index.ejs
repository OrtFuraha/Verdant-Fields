          <a href="#">Help Center</a>
          <a href="#">FAQs</a>
          <a href="#">Blog</a>
          <a href="#">Documentation</a>
          <a href="#">Research</a>
        </div>
      </div>
      <div class="row g-4 mt-3">
        <div class="col-md-4">
          <h6>Contact</h6>
          <p style="font-size: 0.85rem; opacity: 0.6;"><i class="fas fa-envelope me-2"></i>info@verdantfields.com</p>
          <p style="font-size: 0.85rem; opacity: 0.6;"><i class="fas fa-phone me-2"></i>+250 788 123 456</p>
          <p style="font-size: 0.85rem; opacity: 0.6;"><i class="fas fa-map-marker-alt me-2"></i>KN 2 St, Kigali, Rwanda</p>
        </div>
        <div class="col-md-4">
          <h6>Newsletter</h6>
          <div class="input-group">
            <input type="email" class="form-control" placeholder="Your email" style="border-radius: 50px 0 0 50px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: #ffffff;">
            <button class="btn" style="background: #4CAF50; color: #ffffff; border-radius: 0 50px 50px 0; border: none;">Subscribe</button>
