        <ul class="navbar-nav mx-auto">
          <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-home"></i>Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/marketplace"><i class="fas fa-store"></i>Marketplace</a></li>
          <li class="nav-item"><a class="nav-link" href="/mart"><i class="fas fa-shopping-bag"></i>Verdant Mart</a></li>
          <li class="nav-item"><a class="nav-link" href="/education"><i class="fas fa-graduation-cap"></i>Education</a></li>
          <li class="nav-item"><a class="nav-link active" href="/farmers"><i class="fas fa-tractor"></i>Farmers</a></li>
        </ul>
        <div class="d-flex gap-2">
          <a href="/auth/login" class="btn btn-sm" style="background: transparent; color: #0B3D2E; border: 1px solid #0B3D2E; border-radius: 50px; padding: 6px 20px;">Sign In</a>
          <a href="/auth/register" class="btn btn-sm" style="background: #1B5E20; color: #ffffff; border-radius: 50px; padding: 6px 20px; border: none;">Register</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- ============================================
  HERO SECTION - No Overlay
  ============================================ -->
  <section class="hero-farmers">
    <div class="container hero-content">
      <span class="hero-badge">
        <i class="fas fa-circle me-2" style="color: #4CAF50; font-size: 0.4rem;"></i> DIGITAL FARM MANAGEMENT
      </span>
      <h1 class="hero-title">
        Empowering Farmers with<br>
        <span class="highlight">Digital Tools & Insights</span>
      </h1>
      <p class="hero-subtitle">
        Manage your farm operations, track revenue, monitor crop health, 
        and access AI-powered recommendations all in one place.
      </p>
      <div class="hero-buttons">
        <a href="#" class="btn-primary-green">
          <i class="fas fa-tachometer-alt me-2"></i>Go to Dashboard
        </a>
        <a href="#" class="btn-outline-white">
          <i class="fas fa-plus-circle me-2"></i>Add New Farm
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
  TODAY'S WEATHER WITH CHART
  ============================================ -->
  <section class="weather-section">
    <div class="container">
      <div class="text-center mb-4">
        <span class="section-badge">Weather</span>
        <h2 class="section-title mt-2">Today's Weather Forecast</h2>
        <p class="section-subtitle mx-auto">Real-time weather data for your farm location</p>
      </div>
      
      <div class="row g-4">
        <!-- Weather Card -->
        <div class="col-lg-4">
          <div class="weather-card">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div style="font-size: 0.9rem; color: #888;">Today</div>
                <div class="weather-temp">28°C</div>
                <div class="weather-condition">Sunny with light clouds</div>
              </div>
              <div class="weather-icon"><i class="fas fa-sun"></i></div>
            </div>
            
            <div class="weather-details-grid">
              <div class="weather-detail-item">
                <span class="label">Rain Forecast</span>
                <span class="value">0%</span>
              </div>
              <div class="weather-detail-item">
                <span class="label">Wind Speed</span>
                <span class="value">12 km/h</span>
              </div>
              <div class="weather-detail-item">
                <span class="label">Humidity</span>
                <span class="value">65%</span>
              </div>
              <div class="weather-detail-item">
                <span class="label">UV Index</span>
                <span class="value">Moderate</span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Weather Chart -->
        <div class="col-lg-8">
          <div class="chart-container">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 style="font-weight: 600; color: #0B3D2E; margin: 0;">
                <i class="fas fa-chart-line me-2"></i>5-Day Weather Forecast
              </h6>
              <span class="badge" style="background: rgba(76, 175, 80, 0.1); color: #4CAF50; padding: 4px 12px;">
                <i class="fas fa-circle" style="font-size: 0.4rem; margin-right: 4px;"></i> Live
              </span>
            </div>
            <canvas id="weatherChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
  FOOTER
  ============================================ -->
  <footer class="footer-premium">
    <div class="container">
      <div class="row g-4">
