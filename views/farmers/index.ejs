        </div>
        <div class="col-lg-3 col-md-6">
          <h6>Platform</h6>
          <a href="/marketplace">Marketplace</a>
          <a href="/education">Education</a>
          <a href="/farmers">Farmer Portal</a>
          <a href="#">Buyer Portal</a>
