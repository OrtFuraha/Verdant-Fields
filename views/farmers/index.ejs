<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Farmers - Verdant Fields</title>
  
  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  
  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  
  <style>
    :root {
      --primary-dark: #0B3D2E;
      --primary: #1B5E20;
      --primary-light: #2E7D32;
      --secondary: #4CAF50;
      --gold: #D4A017;
      --gold-light: #F5D06B;
      --earth: #5D4037;
      --light-gray: #f5f7f5;
      --white: #ffffff;
      --shadow: 0 4px 20px rgba(0,0,0,0.06);
      --shadow-hover: 0 12px 40px rgba(0,0,0,0.1);
      --radius: 16px;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', sans-serif;
      background: #f8faf8;
      color: #1a1a1a;
      overflow-x: hidden;
    }
    
    /* Remove all animations */
    * {
      animation: none !important;
      transition: none !important;
    }
    
    /* Hero Section - No overlay */
    .hero-farmers {
      min-height: 85vh;
      background: url('/images/Farmer mage Jul 19, 2026, 12_14_35 PM.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      position: relative;
      display: flex;
      align-items: center;
      padding: 80px 0;
    }
    
    .hero-farmers .hero-content {
      position: relative;
      z-index: 2;
      background: rgba(0, 0, 0, 0.3);
      padding: 40px 50px;
      border-radius: 20px;
      backdrop-filter: blur(2px);
      max-width: 700px;
    }
    
    .hero-farmers .hero-title {
      font-size: 3.5rem;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      text-shadow: 0 2px 20px rgba(0,0,0,0.3);
      margin-bottom: 16px;
    }
    
    .hero-farmers .hero-title .highlight {
      color: #4CAF50;
    }
    
    .hero-farmers .hero-subtitle {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.9);
      max-width: 600px;
      line-height: 1.8;
      text-shadow: 0 2px 10px rgba(0,0,0,0.3);
      margin-bottom: 24px;
    }
    
    .hero-farmers .hero-badge {
      display: inline-block;
      background: rgba(212, 160, 23, 0.2);
      color: #D4A017;
      padding: 6px 18px;
      border-radius: 50px;
      border: 1px solid rgba(212, 160, 23, 0.3);
      font-size: 0.75rem;
      font-weight: 600;
      margin-bottom: 20px;
    }
    
    .hero-farmers .hero-buttons {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-top: 24px;
    }
    
    .btn-primary-green {
      background: #1B5E20;
      color: #ffffff;
      padding: 14px 36px;
      border-radius: 50px;
      font-weight: 600;
      border: none;
    }
    
    .btn-primary-green:hover {
      background: #0B3D2E;
      color: #ffffff;
    }
    
    .btn-outline-white {
      background: transparent;
      color: #ffffff;
      padding: 14px 36px;
      border-radius: 50px;
      font-weight: 600;
      border: 2px solid rgba(255,255,255,0.3);
    }
    
    .btn-outline-white:hover {
      background: rgba(255,255,255,0.1);
      color: #ffffff;
    }
    
    /* Weather Section */
    .weather-section {
      padding: 60px 0;
      background: #f8faf8;
    }
    
    .section-title {
      font-size: 2rem;
      font-weight: 800;
      color: #0B3D2E;
    }
    
    .section-subtitle {
      font-size: 1rem;
      color: #666;
      max-width: 600px;
      line-height: 1.7;
    }
    
    .section-badge {
      display: inline-block;
      background: rgba(27, 94, 32, 0.06);
      color: #1B5E20;
      padding: 4px 16px;
      border-radius: 50px;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .weather-card {
      background: #ffffff;
      border-radius: var(--radius);
      padding: 30px;
      border: 1px solid rgba(0,0,0,0.04);
      box-shadow: var(--shadow);
      height: 100%;
    }
    
    .weather-card .weather-temp {
      font-size: 3.5rem;
      font-weight: 800;
      color: #0B3D2E;
    }
    
    .weather-card .weather-condition {
      font-size: 1.1rem;
      color: #555;
    }
    
    .weather-card .weather-icon {
      font-size: 4rem;
      color: #D4A017;
    }
    
    .weather-details-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 16px;
    }
    
    .weather-detail-item {
      display: flex;
      flex-direction: column;
      padding: 12px;
      background: rgba(27, 94, 32, 0.03);
      border-radius: 10px;
    }
    
    .weather-detail-item .label {
      font-size: 0.8rem;
      color: #888;
    }
    
    .weather-detail-item .value {
      font-size: 1.1rem;
      font-weight: 600;
      color: #0B3D2E;
    }
    
    .chart-container {
      background: #ffffff;
      border-radius: var(--radius);
      padding: 24px;
      border: 1px solid rgba(0,0,0,0.04);
      box-shadow: var(--shadow);
      height: 100%;
    }
    
    .chart-container canvas {
      width: 100% !important;
      height: 250px !important;
    }
    
    /* Navbar */
    .navbar-premium {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(0,0,0,0.04);
      padding: 10px 0;
    }
    
    .navbar-premium .nav-link {
      color: #555 !important;
      font-weight: 500;
      font-size: 0.85rem;
      padding: 6px 16px !important;
    }
    
    .navbar-premium .nav-link i {
      margin-right: 6px;
    }
    
    .navbar-premium .nav-link:hover {
      color: #0B3D2E !important;
    }
    
    .navbar-premium .nav-link.active {
      color: #0B3D2E !important;
      font-weight: 600;
    }
    
    .navbar-premium .brand {
      color: #0B3D2E;
      font-weight: 800;
      font-size: 1.2rem;
    }
    
    .navbar-premium .brand i {
      color: #4CAF50;
    }
    
    /* Footer */
    .footer-premium {
      background: #0B3D2E;
      color: rgba(255,255,255,0.7);
      padding: 40px 0 20px;
    }
    
    .footer-premium h6 {
      color: #ffffff;
      font-weight: 600;
      font-size: 0.9rem;
    }
    
    .footer-premium a {
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.85rem;
      display: block;
      padding: 4px 0;
    }
    
    .footer-premium a:hover {
      color: #4CAF50;
    }
    
    .footer-premium .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.05);
      padding-top: 20px;
      margin-top: 20px;
      text-align: center;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.4);
    }
    
    .footer-premium .social-icons a {
      display: inline-block;
      margin-right: 12px;
      font-size: 1.1rem;
      color: rgba(255,255,255,0.5);
    }
    
    .footer-premium .social-icons a:hover {
      color: #4CAF50;
    }
    
    /* Responsive */
    @media (max-width: 992px) {
      .hero-farmers .hero-title {
        font-size: 2.5rem;
      }
      .hero-farmers .hero-content {
        padding: 30px;
      }
    }
    
    @media (max-width: 768px) {
      .hero-farmers .hero-title {
        font-size: 2rem;
      }
      .hero-farmers {
        min-height: 70vh;
        padding: 40px 0;
      }
      .hero-farmers .hero-content {
        padding: 20px;
      }
      .section-title {
        font-size: 1.6rem;
      }
      .weather-card .weather-temp {
        font-size: 2.5rem;
      }
      .weather-details-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
    
    @media (max-width: 576px) {
      .hero-farmers .hero-title {
        font-size: 1.6rem;
      }
      .hero-farmers .hero-content {
        padding: 16px;
      }
      .btn-primary-green,
      .btn-outline-white {
        padding: 10px 24px;
        font-size: 0.9rem;
        width: 100%;
        text-align: center;
      }
      .hero-farmers .hero-buttons {
        flex-direction: column;
      }
      .weather-details-grid {
        grid-template-columns: 1fr;
      }
      .weather-card .weather-temp {
        font-size: 2rem;
      }
    }
  </style>
</head>
<body>
  
  <!-- ============================================
  NAVBAR
  ============================================ -->
  <nav class="navbar navbar-expand-lg navbar-premium sticky-top">
    <div class="container">
      <a class="navbar-brand brand" href="/">
