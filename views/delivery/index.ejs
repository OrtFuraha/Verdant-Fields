<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container py-4">
    <h4><i class="fas fa-truck text-success me-2"></i>My Deliveries</h4>
    
    <div class="row g-4">
      <% if (deliveries && deliveries.length) { %>
        <% deliveries.forEach(delivery => { %>
          <div class="col-md-6">
            <div class="card shadow-sm">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <h6>Delivery #<%= delivery.id %></h6>
                  <span class="badge bg-<%= delivery.status === 'completed' ? 'success' : delivery.status === 'assigned' ? 'warning' : 'info' %>">
                    <%= delivery.status %>
                  </span>
                </div>
                <p><strong>Order:</strong> <%= delivery.order_number %></p>
                <p><strong>Customer:</strong> <%= delivery.first_name %> <%= delivery.last_name %></p>
                <p><strong>Address:</strong> <%= delivery.delivery_address %></p>
                <p><strong>Phone:</strong> <%= delivery.phone %></p>
                
                <% if (delivery.status !== 'completed') { %>
                  <form action="/delivery/<%= delivery.id %>/status" method="POST" class="mt-3">
                    <div class="row g-2">
                      <div class="col-8">
                        <select name="status" class="form-select form-select-sm">
                          <option value="assigned" <%= delivery.status === 'assigned' ? 'selected' : '' %>>Assigned</option>
                          <option value="picked" <%= delivery.status === 'picked' ? 'selected' : '' %>>Picked Up</option>
                          <option value="in_transit" <%= delivery.status === 'in_transit' ? 'selected' : '' %>>In Transit</option>
                          <option value="completed" <%= delivery.status === 'completed' ? 'selected' : '' %>>Completed</option>
                        </select>
                      </div>
                      <div class="col-4">
                        <button type="submit" class="btn btn-success btn-sm w-100">Update</button>
                      </div>
                    </div>
                  </form>
                <% } %>
                
                <div class="mt-2">
                  <small class="text-muted">Created: <%= new Date(delivery.created_at).toLocaleString() %></small>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12 text-center py-5">
          <i class="fas fa-truck fa-4x text-muted mb-3"></i>
          <h5>No deliveries assigned</h5>
          <p class="text-muted">Check back later for new deliveries</p>
        </div>
      <% } %>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
