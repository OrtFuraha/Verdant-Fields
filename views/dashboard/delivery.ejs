<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container-fluid py-4">
    <div class="row">
      <!-- Sidebar -->
      <div class="col-md-2">
        <div class="card shadow-sm mb-4">
          <div class="card-body text-center">
            <i class="fas fa-truck fa-4x text-success"></i>
            <h5 class="mt-2">Rider Panel</h5>
            <p class="text-muted small"><%= user.email %></p>
          </div>
        </div>
        
        <div class="list-group shadow-sm">
          <a href="/dashboard/delivery" class="list-group-item list-group-item-action active bg-success border-success">
            <i class="fas fa-tachometer-alt me-2"></i>Dashboard
          </a>
          <a href="/dashboard/delivery/assigned" class="list-group-item list-group-item-action">
            <i class="fas fa-clipboard-list me-2"></i>Assigned Deliveries
          </a>
          <a href="/dashboard/delivery/history" class="list-group-item list-group-item-action">
            <i class="fas fa-history me-2"></i>Delivery History
          </a>
          <a href="/dashboard/delivery/earnings" class="list-group-item list-group-item-action">
            <i class="fas fa-money-bill me-2"></i>Earnings
          </a>
          <a href="/dashboard/delivery/map" class="list-group-item list-group-item-action">
            <i class="fas fa-map me-2"></i>GPS Map
          </a>
        </div>
      </div>
      
      <!-- Main Content -->
      <div class="col-md-10">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h4><i class="fas fa-truck text-success me-2"></i>Delivery Dashboard</h4>
          <div>
            <span class="badge bg-success me-2"><i class="fas fa-circle me-1"></i>Online</span>
            <span class="text-muted"><%= new Date().toLocaleString() %></span>
          </div>
        </div>
        
        <!-- Stats Cards -->
        <div class="row g-4 mb-4">
          <div class="col-md-3">
            <div class="card shadow-sm dashboard-card bg-primary text-white">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6>Assigned</h6>
                    <h3 class="mb-0"><%= assigned %></h3>
                  </div>
                  <i class="fas fa-clipboard-list fa-2x opacity-50"></i>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm dashboard-card bg-success text-white">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6>Completed</h6>
                    <h3 class="mb-0"><%= completed %></h3>
                  </div>
                  <i class="fas fa-check-circle fa-2x opacity-50"></i>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm dashboard-card bg-warning text-white">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6>Earnings</h6>
                    <h3 class="mb-0">$<%= earnings %></h3>
                  </div>
                  <i class="fas fa-dollar-sign fa-2x opacity-50"></i>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm dashboard-card bg-info text-white">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6>Rating</h6>
                    <h3 class="mb-0">4.9 ★</h3>
                  </div>
                  <i class="fas fa-star fa-2x opacity-50"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Recent Deliveries -->
        <div class="card shadow-sm">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="fas fa-clock text-success me-2"></i>Recent Deliveries</h6>
            <a href="/dashboard/delivery/assigned" class="btn btn-sm btn-outline-success">View All</a>
          </div>
          <div class="card-body">
            <% if (recentDeliveries && recentDeliveries.length) { %>
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Delivery ID</th>
                      <th>Order #</th>
                      <th>Status</th>
                      <th>Distance</th>
                      <th>Date</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recentDeliveries.forEach(delivery => { %>
                      <tr>
                        <td>#DEL-<%= delivery.id %></td>
                        <td><%= delivery.order_number || 'N/A' %></td>
                        <td>
                          <span class="badge bg-<%= delivery.status === 'completed' ? 'success' : delivery.status === 'assigned' ? 'warning' : 'info' %>">
                            <%= delivery.status %>
                          </span>
                        </td>
                        <td><%= delivery.distance || 'N/A' %> km</td>
                        <td><%= new Date(delivery.created_at).toLocaleDateString() %></td>
                        <td>
                          <button class="btn btn-sm btn-outline-success">
                            <i class="fas fa-map"></i>
                          </button>
                          <button class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-eye"></i>
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p class="text-muted text-center">No deliveries yet</p>
            <% } %>
          </div>
        </div>
        
        <!-- Status Update -->
        <div class="card shadow-sm mt-4">
          <div class="card-header bg-white">
            <h6 class="mb-0"><i class="fas fa-toggle-on text-success me-2"></i>Availability Status</h6>
          </div>
          <div class="card-body">
            <div class="d-flex gap-3">
              <button class="btn btn-success">
                <i class="fas fa-check-circle me-2"></i>Available
              </button>
              <button class="btn btn-secondary">
                <i class="fas fa-pause-circle me-2"></i>On Break
              </button>
              <button class="btn btn-danger">
                <i class="fas fa-times-circle me-2"></i>Offline
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
