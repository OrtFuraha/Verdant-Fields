<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container-fluid py-4">
    <div class="row">
      <!-- Sidebar -->
      <div class="col-md-2">
        <div class="card shadow-sm mb-4">
          <div class="card-body text-center">
            <i class="fas fa-tractor fa-4x text-success"></i>
            <h5 class="mt-2">Farmer Panel</h5>
            <p class="text-muted small"><%= user.email %></p>
          </div>
        </div>
        
        <div class="list-group shadow-sm">
          <a href="/dashboard/farmer" class="list-group-item list-group-item-action active bg-success border-success">
            <i class="fas fa-tachometer-alt me-2"></i>Dashboard
          </a>
          <a href="/dashboard/farmer/farm" class="list-group-item list-group-item-action">
            <i class="fas fa-building me-2"></i>Farm Profile
          </a>
          <a href="/dashboard/farmer/verify" class="list-group-item list-group-item-action">
            <i class="fas fa-check-circle me-2"></i>Verification
          </a>
          <a href="/dashboard/farmer/products" class="list-group-item list-group-item-action">
            <i class="fas fa-box me-2"></i>My Products
          </a>
          <a href="/dashboard/farmer/add-product" class="list-group-item list-group-item-action">
            <i class="fas fa-plus-circle me-2"></i>Add Product
          </a>
          <a href="/dashboard/farmer/inventory" class="list-group-item list-group-item-action">
            <i class="fas fa-warehouse me-2"></i>Inventory
          </a>
          <a href="/dashboard/farmer/orders" class="list-group-item list-group-item-action">
            <i class="fas fa-shopping-bag me-2"></i>Orders
          </a>
          <a href="/dashboard/farmer/sales" class="list-group-item list-group-item-action">
            <i class="fas fa-chart-line me-2"></i>Sales
          </a>
          <a href="/dashboard/farmer/revenue" class="list-group-item list-group-item-action">
            <i class="fas fa-dollar-sign me-2"></i>Revenue
          </a>
          <a href="/dashboard/farmer/wallet" class="list-group-item list-group-item-action">
            <i class="fas fa-wallet me-2"></i>Wallet
          </a>
          <a href="/dashboard/farmer/withdraw" class="list-group-item list-group-item-action">
            <i class="fas fa-arrow-up me-2"></i>Withdraw
          </a>
          <a href="/dashboard/farmer/analytics" class="list-group-item list-group-item-action">
            <i class="fas fa-chart-bar me-2"></i>Analytics
          </a>
          <a href="/dashboard/farmer/prices" class="list-group-item list-group-item-action">
            <i class="fas fa-tags me-2"></i>Market Prices
          </a>
          <a href="/dashboard/farmer/education" class="list-group-item list-group-item-action">
            <i class="fas fa-graduation-cap me-2"></i>Education
          </a>
        </div>
      </div>
      
      <!-- Main Content -->
      <div class="col-md-10">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h4><i class="fas fa-tractor text-success me-2"></i>Farmer Dashboard</h4>
          <div>
            <span class="badge bg-success me-2"><i class="fas fa-circle me-1"></i>Active</span>
            <span class="text-muted"><%= new Date().toLocaleString() %></span>
          </div>
        </div>
        
        <!-- Stats Cards -->
        <div class="row g-4 mb-4">
          <div class="col-md-3">
            <div class="card shadow-sm dashboard-card bg-primary text-white">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6>My Products</h6>
                    <h3 class="mb-0"><%= products %></h3>
                  </div>
                  <i class="fas fa-box fa-2x opacity-50"></i>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm dashboard-card bg-success text-white">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6>Total Orders</h6>
                    <h3 class="mb-0"><%= orders %></h3>
                  </div>
                  <i class="fas fa-shopping-bag fa-2x opacity-50"></i>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm dashboard-card bg-warning text-white">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6>Revenue</h6>
                    <h3 class="mb-0">$<%= revenue %></h3>
                  </div>
                  <i class="fas fa-dollar-sign fa-2x opacity-50"></i>
                </div>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card shadow-sm dashboard-card bg-info text-white">
              <div class="card-body">
                <div class="d-flex justify-content-between">
                  <div>
                    <h6>Farm Status</h6>
                    <h3 class="mb-0"><%= farm ? 'Verified' : 'Pending' %></h3>
                  </div>
                  <i class="fas fa-building fa-2x opacity-50"></i>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Farm Profile Card -->
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-white">
            <h6 class="mb-0"><i class="fas fa-building text-success me-2"></i>Farm Profile</h6>
          </div>
          <div class="card-body">
            <% if (farm) { %>
              <div class="row">
                <div class="col-md-6">
                  <p><strong>Farm Name:</strong> <%= farm.name %></p>
                  <p><strong>Location:</strong> <%= farm.city || 'N/A' %>, <%= farm.state || 'N/A' %></p>
                  <p><strong>Size:</strong> <%= farm.size || 'Not specified' %></p>
                </div>
                <div class="col-md-6">
                  <p><strong>Organic Certified:</strong> <%= farm.organic_certified ? '✅ Yes' : '❌ No' %></p>
                  <p><strong>Verified:</strong> <%= farm.verified ? '✅ Yes' : '⏳ Pending' %></p>
                  <p><strong>Member Since:</strong> <%= new Date(farm.created_at).toLocaleDateString() %></p>
                </div>
              </div>
            <% } else { %>
              <div class="text-center py-4">
                <i class="fas fa-building fa-3x text-muted mb-3"></i>
                <p class="text-muted">No farm profile yet</p>
                <a href="/dashboard/farmer/farm" class="btn btn-success">Create Farm Profile</a>
              </div>
            <% } %>
          </div>
        </div>
        
        <!-- Recent Orders -->
        <div class="card shadow-sm">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="fas fa-clock text-success me-2"></i>Recent Orders</h6>
            <a href="/dashboard/farmer/orders" class="btn btn-sm btn-outline-success">View All</a>
          </div>
          <div class="card-body">
            <% if (recentOrders && recentOrders.length) { %>
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Order #</th>
                      <th>Customer</th>
                      <th>Amount</th>
                      <th>Status</th>
                      <th>Date</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% recentOrders.forEach(order => { %>
                      <tr>
                        <td><%= order.order_number %></td>
                        <td>Customer #<%= order.user_id %></td>
                        <td>$<%= order.final_amount %></td>
                        <td>
                          <span class="badge bg-<%= order.status === 'delivered' ? 'success' : order.status === 'cancelled' ? 'danger' : order.status === 'pending' ? 'warning' : 'info' %>">
                            <%= order.status %>
                          </span>
                        </td>
                        <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                        <td>
                          <a href="/orders/<%= order.id %>" class="btn btn-sm btn-outline-success">
                            <i class="fas fa-eye"></i>
                          </a>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p class="text-muted text-center">No orders yet</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
