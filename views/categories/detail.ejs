<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= categoryName %> - Verdant Fields</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .category-hero {
      background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%);
      padding: 40px 0;
      color: white;
      margin-bottom: 30px;
    }
    .category-icon {
      font-size: 3rem;
      margin-right: 20px;
    }
    .breadcrumb-item a {
      color: #2E7D32;
      text-decoration: none;
    }
    .breadcrumb-item a:hover {
      color: #1B5E20;
      text-decoration: underline;
    }
    .filter-sidebar {
      position: sticky;
      top: 80px;
    }
    @media (max-width: 768px) {
      .filter-sidebar {
        position: relative;
        top: 0;
      }
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <!-- Category Hero -->
  <div class="category-hero">
    <div class="container">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><a href="/" class="text-white-50">Home</a></li>
          <li class="breadcrumb-item"><a href="/categories" class="text-white-50">Categories</a></li>
          <li class="breadcrumb-item active text-white" aria-current="page"><%= categoryName %></li>
        </ol>
      </nav>
      <div class="d-flex align-items-center">
        <div class="category-icon">
          <i class="<%= icon %>"></i>
        </div>
        <div>
          <h1 class="display-5 fw-bold"><%= categoryName %></h1>
          <p class="lead mb-0"><%= productCount %> Products Available</p>
        </div>
      </div>
    </div>
  </div>
  
  <div class="container">
    <div class="row">
      <!-- Filters Sidebar -->
      <div class="col-lg-3">
        <div class="filter-sidebar">
          <div class="card shadow-sm mb-3">
            <div class="card-body">
              <h6 class="fw-bold"><i class="fas fa-sliders-h text-success me-2"></i>Filters</h6>
              <hr>
              <div class="mb-3">
                <label class="fw-bold small">Price Range</label>
                <input type="range" class="form-range" min="0" max="100">
                <div class="d-flex justify-content-between">
                  <span class="small">$0</span>
                  <span class="small">$100</span>
                </div>
              </div>
              <div class="mb-3">
                <label class="fw-bold small">Rating</label>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="rating5">
                  <label class="form-check-label" for="rating5">★★★★★ (5.0)</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="rating4">
                  <label class="form-check-label" for="rating4">★★★★☆ (4.0+)</label>
                </div>
              </div>
              <div class="mb-3">
                <label class="fw-bold small">Availability</label>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="inStock">
                  <label class="form-check-label" for="inStock">In Stock</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="organic">
                  <label class="form-check-label" for="organic">Organic</label>
                </div>
              </div>
              <button class="btn btn-success w-100" onclick="applyFilters()">
                <i class="fas fa-check me-2"></i>Apply Filters
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Products -->
      <div class="col-lg-9">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <span class="text-muted">Showing 1-12 of <%= productCount %> products</span>
          <select class="form-select w-auto">
            <option>Sort by: Newest</option>
            <option>Price: Low to High</option>
            <option>Price: High to Low</option>
            <option>Top Rated</option>
          </select>
        </div>
        
        <div class="row g-4">
          <% for(let i=1; i<=12; i++) { %>
            <div class="col-lg-4 col-md-6">
              <div class="product-card h-100 shadow-sm">
                <div class="product-image">
                  <img src="https://images.unsplash.com/photo-1542838132-92c53300491e?w=400&h=300&fit=crop" alt="<%= categoryName %> Product">
                  <% if (i % 2 === 0) { %>
                    <span class="product-badge organic">Organic</span>
                  <% } %>
                  <% if (i % 3 === 0) { %>
                    <span class="product-badge discount" style="left: auto; right: 12px; top: 48px;">-15%</span>
                  <% } %>
                  <div class="product-actions">
                    <button onclick="toggleWishlist(this)"><i class="far fa-heart"></i></button>
                    <button onclick="quickView()"><i class="fas fa-eye"></i></button>
                  </div>
                </div>
                <div class="product-body">
                  <div class="product-name"><%= categoryName %> Product <%= i %></div>
                  <div class="product-farmer"><i class="fas fa-user me-1"></i>Local Farm</div>
                  <div class="product-price">
                    <span class="current">$<%= (4.99 + i * 0.5).toFixed(2) %></span>
                    <% if (i % 3 === 0) { %>
                      <span class="original">$<%= (6.99 + i * 0.5).toFixed(2) %></span>
                    <% } %>
                  </div>
                  <div class="product-rating">
                    <span class="stars">
                      <i class="fas fa-star"></i><i class="fas fa-star"></i>
                      <i class="fas fa-star"></i><i class="fas fa-star"></i>
                      <i class="fas fa-star-<%= i % 2 === 0 ? 'half-alt' : 'star' %>"></i>
                    </span>
                    <span class="count">(<%= 20 + i * 5 %> reviews)</span>
                  </div>
                  <div class="product-footer">
                    <span class="availability <%= i % 4 === 0 ? 'out-of-stock' : 'in-stock' %>">
                      <i class="fas fa-<%= i % 4 === 0 ? 'times-circle' : 'check-circle' %> me-1"></i>
                      <%= i % 4 === 0 ? 'Out of Stock' : 'In Stock' %>
                    </span>
                    <button class="btn btn-sm <%= i % 4 === 0 ? 'btn-secondary' : 'btn-success' %>" 
                            onclick="addToCart()" <%= i % 4 === 0 ? 'disabled' : '' %>>
                      <i class="fas fa-cart-plus"></i>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          <% } %>
        </div>
        
        <!-- Pagination -->
        <nav class="mt-4">
          <ul class="pagination justify-content-center">
            <li class="page-item disabled">
              <a class="page-link" href="#" tabindex="-1">Previous</a>
            </li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">4</a></li>
            <li class="page-item">
              <a class="page-link" href="#">Next</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  
  <script>
    function toggleWishlist(btn) {
      btn.classList.toggle('active');
      const icon = btn.querySelector('i');
      if (btn.classList.contains('active')) {
        icon.className = 'fas fa-heart';
        showNotification('Added to wishlist!', 'success');
      } else {
        icon.className = 'far fa-heart';
        showNotification('Removed from wishlist', 'info');
      }
    }
    
    function addToCart() {
      showNotification('Added to cart successfully!', 'success');
    }
    
    function quickView() {
      showNotification('Quick view opened', 'info');
    }
    
    function applyFilters() {
      showNotification('Filters applied!', 'success');
    }
    
    function showNotification(message, type = 'info') {
      const colors = {
        success: 'bg-success',
        info: 'bg-info',
        warning: 'bg-warning text-dark',
        danger: 'bg-danger'
      };
      
      const notification = document.createElement('div');
      notification.className = `alert ${colors[type] || 'bg-info'} text-white position-fixed top-0 end-0 m-3 shadow-lg`;
      notification.style.zIndex = '9999';
      notification.style.minWidth = '250px';
      notification.style.borderRadius = '12px';
      notification.innerHTML = `
        <i class="fas fa-info-circle me-2"></i>
        ${message}
        <button class="btn-close btn-close-white ms-3" onclick="this.parentElement.remove()"></button>
      `;
      
      document.body.appendChild(notification);
      
      setTimeout(() => {
        if (notification.parentElement) {
          notification.style.opacity = '0';
          notification.style.transition = 'opacity 0.5s ease';
          setTimeout(() => notification.remove(), 500);
        }
      }, 3000);
    }
  </script>
</body>
</html>
