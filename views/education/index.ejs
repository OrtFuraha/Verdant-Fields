  <!-- ============================================
  PROFESSIONAL LEARNING PATHS
  ============================================ -->
  <section class="py-5" style="background: #f5f7f5;">
    <div class="container">
      <div class="text-center mb-4">
        <span class="section-badge">Learning Paths</span>
        <h2 class="section-title mt-2">Professional Learning Paths</h2>
        <p class="section-subtitle mx-auto">Choose your career path in agriculture</p>
      </div>
      
      <div class="row g-3">
        <div class="col-lg-2-4 col-md-4 col-6">
          <div class="card-premium text-center">
            <div class="card-icon"><i class="fas fa-user-graduate"></i></div>
            <div class="card-title">Beginner Farmer</div>
            <div class="card-text">12 Courses</div>
          </div>
        </div>
        <div class="col-lg-2-4 col-md-4 col-6">
          <div class="card-premium text-center">
            <div class="card-icon"><i class="fas fa-user-tie"></i></div>
            <div class="card-title">Commercial Farmer</div>
            <div class="card-text">15 Courses</div>
          </div>
        </div>
        <div class="col-lg-2-4 col-md-4 col-6">
          <div class="card-premium text-center">
            <div class="card-icon"><i class="fas fa-users"></i></div>
            <div class="card-title">Cooperative Leader</div>
            <div class="card-text">10 Courses</div>
          </div>
        </div>
        <div class="col-lg-2-4 col-md-4 col-6">
          <div class="card-premium text-center">
            <div class="card-icon"><i class="fas fa-chart-line"></i></div>
            <div class="card-title">Agribusiness Manager</div>
            <div class="card-text">14 Courses</div>
          </div>
        </div>
