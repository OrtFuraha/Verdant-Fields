<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agriculture Innovation & Digital Learning Hub - Verdant Fields</title>
  
  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --primary-dark: #0B3D2E;
      --primary: #1B5E20;
      --primary-light: #2E7D32;
      --secondary: #4CAF50;
      --gold: #D4A017;
      --gold-light: #F5D06B;
      --earth: #5D4037;
      --light-gray: #f5f7f5;
      --white: #ffffff;
      --shadow: 0 4px 20px rgba(0,0,0,0.06);
      --shadow-hover: 0 12px 40px rgba(0,0,0,0.1);
      --radius: 16px;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', sans-serif;
      background: #f8faf8;
      color: #1a1a1a;
      overflow-x: hidden;
    }
    
    /* Remove all animations */
    * {
      animation: none !important;
      transition: none !important;
    }
    
    /* Hero Section */
    .hero-education {
      min-height: 85vh;
      background: url('/images/Education Jul 16, 2026, 04_18_09 PM.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      position: relative;
      display: flex;
      align-items: center;
      padding: 80px 0;
    }
    
    .hero-education::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.55);
      z-index: 0;
    }
    
    .hero-education .hero-content {
      position: relative;
      z-index: 2;
    }
    
    .hero-education .hero-title {
      font-size: 3.5rem;
      font-weight: 900;
      line-height: 1.1;
      color: #ffffff;
      text-shadow: 0 2px 20px rgba(0,0,0,0.3);
      margin-bottom: 16px;
    }
    
    .hero-education .hero-title .highlight {
      color: #4CAF50;
    }
    
    .hero-education .hero-subtitle {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.9);
      max-width: 600px;
      line-height: 1.8;
      text-shadow: 0 2px 10px rgba(0,0,0,0.3);
      margin-bottom: 24px;
    }
    
    .hero-education .hero-badge {
      display: inline-block;
      background: rgba(212, 160, 23, 0.2);
      color: #D4A017;
      padding: 6px 18px;
      border-radius: 50px;
      border: 1px solid rgba(212, 160, 23, 0.3);
      font-size: 0.75rem;
      font-weight: 600;
      margin-bottom: 20px;
    }
    
    .hero-education .hero-buttons {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-top: 24px;
    }
    
    .btn-primary-green {
      background: #1B5E20;
      color: #ffffff;
      padding: 14px 36px;
      border-radius: 50px;
      font-weight: 600;
      border: none;
    }
    
    .btn-primary-green:hover {
      background: #0B3D2E;
      color: #ffffff;
    }
    
    .btn-outline-white {
      background: transparent;
      color: #ffffff;
      padding: 14px 36px;
      border-radius: 50px;
      font-weight: 600;
      border: 2px solid rgba(255,255,255,0.3);
    }
    
    .btn-outline-white:hover {
      background: rgba(255,255,255,0.1);
      color: #ffffff;
    }
    
    .btn-outline-gold {
      background: transparent;
      color: #D4A017;
      padding: 14px 36px;
      border-radius: 50px;
      font-weight: 600;
      border: 2px solid #D4A017;
    }
    
    .btn-outline-gold:hover {
      background: #D4A017;
      color: #0a0a1a;
    }
    
    .btn-outline-green {
      background: transparent;
      color: #1B5E20;
      padding: 8px 20px;
      border-radius: 50px;
      font-weight: 600;
      border: 2px solid #1B5E20;
      font-size: 0.85rem;
    }
    
    .btn-outline-green:hover {
      background: #1B5E20;
      color: #ffffff;
    }
    
    /* Cards */
    .card-premium {
      background: #ffffff;
      border-radius: var(--radius);
      padding: 24px;
      border: 1px solid rgba(0,0,0,0.04);
      box-shadow: var(--shadow);
      height: 100%;
    }
    
    .card-premium .card-icon {
      font-size: 2rem;
      color: #1B5E20;
      margin-bottom: 12px;
    }
    
    .card-premium .card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #0B3D2E;
    }
    
    .card-premium .card-text {
      color: #555;
      font-size: 0.95rem;
      line-height: 1.7;
    }
    
    .card-premium .card-meta {
      font-size: 0.8rem;
      color: #888;
      margin-top: 8px;
    }
    
    /* Course Cards */
    .course-card {
      background: #ffffff;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid rgba(0,0,0,0.04);
      box-shadow: var(--shadow);
      height: 100%;
    }
    
    .course-card .course-image {
      height: 180px;
      background-size: cover;
      background-position: center;
    }
    
    .course-card .course-body {
      padding: 16px;
    }
    
    .course-card .course-body .course-title {
      font-weight: 700;
      font-size: 1.05rem;
      color: #0B3D2E;
      margin-bottom: 4px;
    }
    
    .course-card .course-body .course-instructor {
      font-size: 0.85rem;
      color: #555;
    }
    
    .course-card .course-body .course-meta {
      display: flex;
      gap: 12px;
      font-size: 0.8rem;
      color: #888;
      margin: 8px 0;
      flex-wrap: wrap;
    }
    
    .course-card .course-body .course-meta span {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    
    .course-card .course-body .course-rating {
      color: #D4A017;
      font-size: 0.85rem;
    }
    
    .course-card .course-body .course-badge {
      display: inline-block;
      padding: 2px 12px;
      border-radius: 20px;
      font-size: 0.65rem;
      font-weight: 600;
      margin-right: 4px;
    }
    
    .course-card .course-body .course-badge.beginners {
      background: rgba(76, 175, 80, 0.1);
      color: #4CAF50;
    }
    
    .course-card .course-body .course-badge.intermediate {
      background: rgba(212, 160, 23, 0.1);
      color: #D4A017;
    }
    
    .course-card .course-body .course-badge.advanced {
      background: rgba(244, 67, 54, 0.1);
      color: #f44336;
    }
    
    .course-card .course-body .course-cert {
      display: inline-block;
      background: rgba(27, 94, 32, 0.06);
      color: #1B5E20;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 0.65rem;
      font-weight: 600;
    }
    
    /* Section Titles */
    .section-title {
      font-size: 2.2rem;
      font-weight: 800;
      color: #0B3D2E;
    }
    
    .section-subtitle {
      font-size: 1rem;
      color: #666;
      max-width: 600px;
      line-height: 1.7;
    }
    
    .section-badge {
      display: inline-block;
      background: rgba(27, 94, 32, 0.06);
      color: #1B5E20;
      padding: 4px 16px;
      border-radius: 50px;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    /* Learning Categories Grid */
    .category-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }
    
    .category-item {
      background: #ffffff;
      border-radius: var(--radius);
      padding: 16px;
      text-align: center;
      border: 1px solid rgba(0,0,0,0.04);
      box-shadow: var(--shadow);
    }
    
    .category-item .category-icon {
      font-size: 1.8rem;
      color: #1B5E20;
      margin-bottom: 6px;
    }
    
    .category-item .category-name {
      font-size: 0.85rem;
      font-weight: 600;
      color: #0B3D2E;
    }
    
    .category-item .category-count {
      font-size: 0.7rem;
      color: #888;
    }
    
    /* FAQ */
    .faq-item {
      background: #ffffff;
      border-radius: var(--radius);
      padding: 16px 20px;
      border: 1px solid rgba(0,0,0,0.04);
      box-shadow: var(--shadow);
      margin-bottom: 12px;
    }
    
    .faq-item .faq-question {
      font-weight: 600;
      color: #0B3D2E;
      font-size: 1rem;
    }
    
    .faq-item .faq-answer {
      color: #555;
      font-size: 0.9rem;
      margin-top: 4px;
    }
    
    /* Navbar */
    .navbar-premium {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(0,0,0,0.04);
      padding: 10px 0;
    }
    
    .navbar-premium .nav-link {
      color: #555 !important;
      font-weight: 500;
      font-size: 0.85rem;
      padding: 6px 16px !important;
    }
    
    .navbar-premium .nav-link i {
      margin-right: 6px;
    }
    
    .navbar-premium .nav-link:hover {
      color: #0B3D2E !important;
    }
    
    .navbar-premium .nav-link.active {
      color: #0B3D2E !important;
      font-weight: 600;
    }
    
    .navbar-premium .brand {
      color: #0B3D2E;
      font-weight: 800;
      font-size: 1.2rem;
    }
    
    .navbar-premium .brand i {
      color: #4CAF50;
    }
    
    /* Footer */
    .footer-premium {
      background: #0B3D2E;
      color: rgba(255,255,255,0.7);
      padding: 60px 0 20px;
    }
    
    .footer-premium h6 {
      color: #ffffff;
      font-weight: 600;
      font-size: 0.9rem;
      margin-bottom: 16px;
    }
    
    .footer-premium a {
      color: rgba(255,255,255,0.6);
      text-decoration: none;
      font-size: 0.85rem;
      display: block;
      padding: 4px 0;
    }
    
    .footer-premium a:hover {
      color: #4CAF50;
    }
    
    .footer-premium .social-icons a {
      display: inline-block;
      margin-right: 12px;
      font-size: 1.1rem;
      color: rgba(255,255,255,0.5);
    }
    
    .footer-premium .social-icons a:hover {
      color: #4CAF50;
    }
    
    .footer-premium .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.05);
      padding-top: 20px;
      margin-top: 30px;
      text-align: center;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.4);
    }
    
    .footer-premium .footer-bottom .tagline {
      color: #4CAF50;
      font-weight: 500;
    }
    
    /* Schedule Table */
    .schedule-table {
      width: 100%;
      border-collapse: collapse;
    }
    
    .schedule-table th {
      text-align: left;
      padding: 10px 12px;
      font-weight: 600;
      font-size: 0.8rem;
      color: #555;
      border-bottom: 2px solid rgba(0,0,0,0.04);
    }
    
    .schedule-table td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(0,0,0,0.03);
      font-size: 0.85rem;
      color: #1a1a1a;
    }
    
    .schedule-table tr:hover td {
      background: rgba(27, 94, 32, 0.02);
    }
    
    .schedule-table .status-badge {
      padding: 2px 12px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
    }
    
    .schedule-table .status-badge.open {
      background: rgba(76, 175, 80, 0.1);
      color: #4CAF50;
    }
    
    .schedule-table .status-badge.full {
      background: rgba(244, 67, 54, 0.1);
      color: #f44336;
    }
    
    .schedule-table .status-badge.soon {
      background: rgba(212, 160, 23, 0.1);
      color: #D4A017;
    }
    
    /* Responsive */
    @media (max-width: 992px) {
      .hero-education .hero-title {
        font-size: 2.5rem;
      }
      .category-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media (max-width: 768px) {
      .hero-education .hero-title {
        font-size: 2rem;
      }
      .hero-education {
        min-height: 70vh;
        padding: 40px 0;
      }
      .section-title {
        font-size: 1.8rem;
      }
      .category-grid {
        grid-template-columns: 1fr 1fr;
      }
      .schedule-table {
        font-size: 0.8rem;
      }
      .schedule-table th,
      .schedule-table td {
        padding: 6px 8px;
      }
    }
    
    @media (max-width: 576px) {
      .hero-education .hero-title {
        font-size: 1.6rem;
      }
      .category-grid {
        grid-template-columns: 1fr 1fr;
        gap: 8px;
      }
      .category-item {
        padding: 12px;
      }
      .btn-primary-green,
      .btn-outline-white,
      .btn-outline-gold {
        padding: 10px 24px;
        font-size: 0.9rem;
        width: 100%;
        text-align: center;
      }
      .hero-education .hero-buttons {
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  
  <!-- ============================================
  NAVBAR WITH ICONS
  ============================================ -->
  <nav class="navbar navbar-expand-lg navbar-premium sticky-top">
    <div class="container">
