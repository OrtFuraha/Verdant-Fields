      </div>
    </div>
  </nav>

  <!-- ============================================
  HERO SECTION
  ============================================ -->
  <section class="hero-education">
    <div class="container hero-content">
      <div class="row">
        <div class="col-lg-8">
          <span class="hero-badge">
            <i class="fas fa-circle me-2" style="color: #4CAF50; font-size: 0.4rem;"></i> AGRICULTURE INNOVATION HUB
          </span>
          <h1 class="hero-title">
            Transforming Agriculture Through<br>
            <span class="highlight">Knowledge, Technology & Innovation</span>
          </h1>
          <p class="hero-subtitle">
            Empowering farmers, entrepreneurs, and agriculture professionals with practical training, 
            digital tools, climate intelligence, and market knowledge for sustainable agricultural transformation.
          </p>
          <div class="hero-buttons">
            <a href="#" class="btn-primary-green">
              <i class="fas fa-book-open me-2"></i>Browse Courses
