<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  
  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
  
  <style>
    /* Full screen hero section */
    .hero-full {
      width: 100%;
      height: 100vh;
      background: url('/images/ChatGPT Image Jul 10, 2026, 12_44_19 PM.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      background-attachment: fixed;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      padding: 0;
      margin: 0;
    }
    
    /* Dark overlay for text readability */
    .hero-full::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.35);
      z-index: 0;
    }
    
    .hero-full .hero-content {
      position: relative;
      z-index: 1;
      width: 100%;
      padding: 60px 40px;
    }
    
    .hero-full .hero-content .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 20px;
    }
    
    .hero-title-large {
      font-size: 4.5rem;
      font-weight: 900;
      color: #FFFFFF !important;
      text-shadow: 0 4px 20px rgba(0,0,0,0.5) !important;
      line-height: 1.1;
      margin-bottom: 20px;
      letter-spacing: -1px;
    }
    
    .hero-title-large .highlight {
      color: #FFFFFF !important;
      text-shadow: 0 4px 20px rgba(0,0,0,0.5) !important;
      position: relative;
    }
    
    .hero-title-large .highlight::after {
      content: '';
      position: absolute;
      bottom: 8px;
      left: 0;
      right: 0;
      height: 8px;
      background: #F9A825;
      opacity: 0.4;
      border-radius: 4px;
    }
    
    .hero-subtitle-large {
      color: #FFFFFF !important;
      text-shadow: 0 2px 10px rgba(0,0,0,0.5) !important;
      font-weight: 400;
      font-size: 1.4rem;
      max-width: 600px;
      line-height: 1.8;
      margin-bottom: 30px;
      opacity: 0.95;
    }
    
    .hero-search-large {
      max-width: 600px;
      margin-bottom: 30px;
    }
    
    .hero-search-large .input-group {
      background: rgba(255,255,255,0.95);
      border-radius: 50px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.2);
      backdrop-filter: blur(10px);
    }
    
    .hero-search-large .form-control {
      border: none;
      padding: 16px 24px;
      font-size: 1.1rem;
      border-radius: 50px 0 0 50px;
      background: transparent;
    }
    
    .hero-search-large .form-control:focus {
      box-shadow: none;
    }
    
    .hero-search-large .btn {
      padding: 16px 36px;
      border-radius: 0 50px 50px 0;
      font-weight: 600;
      font-size: 1.1rem;
    }
    
    .btn-hero-large-primary {
      background: #2E7D32;
      color: #FFFFFF;
      padding: 16px 44px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1.1rem;
      border: none;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      box-shadow: 0 4px 20px rgba(46,125,50,0.4);
    }
    
    .btn-hero-large-primary:hover {
      background: #1B5E20;
      color: #FFFFFF;
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(46,125,50,0.5);
    }
    
    .btn-hero-large-secondary {
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(10px);
      border: 2px solid rgba(255,255,255,0.4);
      color: #FFFFFF !important;
      padding: 16px 44px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1.1rem;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }
    
    .btn-hero-large-secondary:hover {
      background: rgba(255,255,255,0.25);
      transform: translateY(-3px);
      border-color: rgba(255,255,255,0.6);
      color: #FFFFFF !important;
    }
    
    /* Stats row */
    .hero-stats-row {
      display: flex;
      gap: 50px;
      margin-top: 40px;
      padding-top: 30px;
      border-top: 1px solid rgba(255,255,255,0.2);
    }
    
    .hero-stats-row .stat-item {
      text-align: left;
    }
    
    .hero-stats-row .stat-number {
      font-size: 2.2rem;
      font-weight: 800;
      color: #FFFFFF;
      text-shadow: 0 2px 10px rgba(0,0,0,0.3);
      line-height: 1;
    }
    
    .hero-stats-row .stat-label {
      font-size: 1rem;
      color: rgba(255,255,255,0.85);
      margin-top: 4px;
      font-weight: 400;
    }
    
    /* Responsive */
    @media (max-width: 992px) {
      .hero-title-large {
        font-size: 3.5rem;
      }
      .hero-subtitle-large {
        font-size: 1.2rem;
      }
      .hero-stats-row {
        gap: 30px;
        flex-wrap: wrap;
      }
    }
    
    @media (max-width: 768px) {
      .hero-full {
        height: 100vh;
        background-attachment: scroll;
      }
      .hero-full .hero-content {
        padding: 40px 20px;
      }
      .hero-title-large {
        font-size: 2.5rem;
      }
      .hero-subtitle-large {
        font-size: 1rem;
      }
      .hero-search-large .form-control {
        padding: 14px 18px;
        font-size: 1rem;
      }
      .hero-search-large .btn {
        padding: 14px 24px;
        font-size: 1rem;
      }
      .btn-hero-large-primary,
      .btn-hero-large-secondary {
        padding: 14px 30px;
        font-size: 1rem;
      }
      .hero-buttons {
        flex-direction: column;
        width: 100%;
      }
      .hero-buttons a {
        width: 100%;
        justify-content: center;
      }
      .hero-stats-row {
        gap: 20px;
        flex-wrap: wrap;
      }
      .hero-stats-row .stat-item {
        flex: 1 1 45%;
      }
    }
    
    @media (max-width: 576px) {
      .hero-title-large {
        font-size: 2rem;
      }
      .hero-subtitle-large {
        font-size: 0.95rem;
      }
      .hero-stats-row .stat-number {
        font-size: 1.6rem;
      }
    }
  </style>
</head>
<body>
  
