<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container py-4">
    <div class="row">
      <div class="col-md-6">
        <img src="/images/products/<%= product.id %>.jpg" class="img-fluid rounded-4 shadow-sm" alt="<%= product.name %>" onerror="this.src='https://via.placeholder.com/600x400/2E7D32/FFFFFF?text=<%= encodeURIComponent(product.name) %>'">
      </div>
      <div class="col-md-6">
        <h2><%= product.name %></h2>
        <p class="text-muted">by <%= product.first_name %> <%= product.last_name %></p>
        <h3 class="text-success">$<%= product.price %></h3>
        <% if (product.discount_price) { %>
          <p class="text-danger">Was $<%= product.price %></p>
        <% } %>
        <p><%= product.description %></p>
        <p><strong>Stock:</strong> <%= product.stock > 0 ? product.stock + ' units' : 'Out of stock' %></p>
        <% if (product.is_organic) { %>
          <span class="badge bg-success mb-3">Organic Certified</span>
        <% } %>
        
        <form action="/products/<%= product.id %>/cart" method="POST" class="mt-3">
          <div class="row g-2">
            <div class="col-4">
              <input type="number" name="quantity" class="form-control" value="1" min="1" max="<%= product.stock %>">
            </div>
            <div class="col-8">
              <button type="submit" class="btn btn-success w-100">
                <i class="fas fa-shopping-cart me-2"></i>Add to Cart
              </button>
            </div>
          </div>
        </form>
        
        <form action="/products/<%= product.id %>/wishlist" method="POST" class="mt-2">
          <button type="submit" class="btn btn-outline-danger w-100">
            <i class="far fa-heart me-2"></i>Add to Wishlist
          </button>
        </form>
      </div>
    </div>
    
    <% if (relatedProducts && relatedProducts.length) { %>
      <div class="mt-5">
        <h4>Related Products</h4>
        <div class="row g-4">
          <% relatedProducts.forEach(related => { %>
            <div class="col-md-3">
              <div class="card product-card h-100 shadow-sm">
                <img src="/images/products/<%= related.id %>.jpg" class="card-img-top" alt="<%= related.name %>" onerror="this.src='https://via.placeholder.com/300x200/2E7D32/FFFFFF?text=<%= encodeURIComponent(related.name) %>'">
                <div class="card-body">
                  <h6><%= related.name %></h6>
                  <p class="text-success">$<%= related.price %></p>
                  <a href="/products/<%= related.id %>" class="btn btn-sm btn-outline-success">View</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
  
  <%- include('../partials/footer') %>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
