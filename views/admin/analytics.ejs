<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <%- include('../partials/navbar') %>
  
  <div class="container-fluid py-4">
    <div class="row">
      <div class="col-md-2">
        <div class="list-group shadow-sm">
          <a href="/admin" class="list-group-item list-group-item-action">
            <i class="fas fa-tachometer-alt me-2"></i>Dashboard
          </a>
          <a href="/admin/users" class="list-group-item list-group-item-action">
            <i class="fas fa-users me-2"></i>Users
          </a>
          <a href="/admin/products" class="list-group-item list-group-item-action">
            <i class="fas fa-box me-2"></i>Products
          </a>
          <a href="/admin/orders" class="list-group-item list-group-item-action">
            <i class="fas fa-shopping-bag me-2"></i>Orders
          </a>
          <a href="/admin/payments" class="list-group-item list-group-item-action">
            <i class="fas fa-credit-card me-2"></i>Payments
          </a>
          <a href="/admin/deliveries" class="list-group-item list-group-item-action">
            <i class="fas fa-truck me-2"></i>Deliveries
          </a>
          <a href="/admin/categories" class="list-group-item list-group-item-action">
            <i class="fas fa-tags me-2"></i>Categories
          </a>
          <a href="/admin/coupons" class="list-group-item list-group-item-action">
            <i class="fas fa-gift me-2"></i>Coupons
          </a>
          <a href="/admin/analytics" class="list-group-item list-group-item-action active bg-success border-success">
            <i class="fas fa-chart-line me-2"></i>Analytics
          </a>
          <a href="/admin/settings" class="list-group-item list-group-item-action">
            <i class="fas fa-cog me-2"></i>Settings
          </a>
        </div>
      </div>
      
      <div class="col-md-10">
        <h4 class="mb-4"><i class="fas fa-chart-line text-success me-2"></i>Analytics Dashboard</h4>
        
        <!-- Time Period Selector -->
        <div class="card shadow-sm mb-4">
          <div class="card-body">
            <div class="row g-2">
              <div class="col-md-3">
                <select class="form-select">
                  <option>Last 7 Days</option>
                  <option>Last 30 Days</option>
                  <option>Last 90 Days</option>
                  <option>This Year</option>
                  <option>Custom Range</option>
                </select>
              </div>
              <div class="col-md-3">
                <input type="date" class="form-control" value="2024-12-01">
              </div>
              <div class="col-md-3">
                <input type="date" class="form-control" value="2024-12-15">
              </div>
              <div class="col-md-3">
                <button class="btn btn-success w-100">Apply</button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Charts Row -->
        <div class="row g-4 mb-4">
          <div class="col-md-6">
            <div class="card shadow-sm">
              <div class="card-header bg-white">
                <h6 class="mb-0"><i class="fas fa-chart-bar text-success me-2"></i>Revenue Trend</h6>
              </div>
              <div class="card-body">
                <canvas id="revenueTrendChart" height="200"></canvas>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card shadow-sm">
              <div class="card-header bg-white">
                <h6 class="mb-0"><i class="fas fa-chart-pie text-success me-2"></i>Product Sales Distribution</h6>
              </div>
              <div class="card-body">
                <canvas id="productSalesChart" height="200"></canvas>
              </div>
            </div>
          </div>
        </div>
        
        <!-- More Charts -->
        <div class="row g-4">
          <div class="col-md-6">
            <div class="card shadow-sm">
              <div class="card-header bg-white">
                <h6 class="mb-0"><i class="fas fa-users text-success me-2"></i>User Growth</h6>
              </div>
              <div class="card-body">
                <canvas id="userGrowthChart" height="200"></canvas>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card shadow-sm">
              <div class="card-header bg-white">
                <h6 class="mb-0"><i class="fas fa-tag text-success me-2"></i>Top Categories</h6>
              </div>
              <div class="card-body">
                <canvas id="topCategoriesChart" height="200"></canvas>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Revenue Trend Chart
    const ctx1 = document.getElementById('revenueTrendChart').getContext('2d');
    new Chart(ctx1, {
      type: 'line',
      data: {
        labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
        datasets: [{
          label: 'Revenue',
          data: [1200, 1900, 1500, 2500, 2200, 3000, 2800],
          borderColor: '#2E7D32',
          backgroundColor: 'rgba(46, 125, 50, 0.1)',
          tension: 0.4,
          fill: true
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          }
        }
      }
    });
    
    // Product Sales Chart
    const ctx2 = document.getElementById('productSalesChart').getContext('2d');
    new Chart(ctx2, {
      type: 'doughnut',
      data: {
        labels: ['Vegetables', 'Fruits', 'Organic', 'Dairy', 'Others'],
        datasets: [{
          data: [35, 25, 20, 12, 8],
          backgroundColor: ['#2E7D32', '#4CAF50', '#66BB6A', '#F9A825', '#FB8C00'],
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom'
          }
        }
      }
    });
    
    // User Growth Chart
    const ctx3 = document.getElementById('userGrowthChart').getContext('2d');
    new Chart(ctx3, {
      type: 'bar',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [{
          label: 'New Users',
          data: [120, 150, 180, 200, 250, 300],
          backgroundColor: '#2E7D32',
          borderRadius: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          }
        }
      }
    });
    
    // Top Categories Chart
    const ctx4 = document.getElementById('topCategoriesChart').getContext('2d');
    new Chart(ctx4, {
      type: 'bar',
      data: {
        labels: ['Vegetables', 'Fruits', 'Organic', 'Dairy', 'Seeds'],
        datasets: [{
          label: 'Products Sold',
          data: [450, 380, 320, 250, 180],
          backgroundColor: ['#2E7D32', '#4CAF50', '#66BB6A', '#F9A825', '#FB8C00'],
          borderRadius: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          }
        },
        scales: {
          y: {
            beginAtZero: true
          }
        }
      }
    });
  </script>
</body>
</html>
