<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', sans-serif;
      background: #ffffff;
      min-height: 100vh;
    }
    
    .login-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: #ffffff;
    }
    
    .login-wrapper {
      width: 100%;
      max-width: 1200px;
      min-height: 600px;
      background: white;
      border-radius: 24px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.15);
      display: flex;
      overflow: hidden;
      position: relative;
    }
    
    /* Left Side - Image without gradient overlay */
    .login-left {
      flex: 1;
      background: url('/images/ChatGPT Image Jul 10, 2026, 12_43_56 PM.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      position: relative;
      min-height: 500px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    /* No gradient overlay - removed */
    .login-left-content {
      position: relative;
      z-index: 1;
      color: white;
      padding: 50px;
      text-align: center;
    }
    
    .login-left-content .brand-icon {
      font-size: 4rem;
      margin-bottom: 20px;
      display: block;
      text-shadow: 0 2px 10px rgba(0,0,0,0.3);
    }
    
    .login-left-content h2 {
      font-weight: 800;
      font-size: 2.5rem;
      margin-bottom: 16px;
      text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }
    
    .login-left-content p {
      opacity: 0.95;
      font-size: 1.1rem;
      line-height: 1.8;
      max-width: 400px;
      margin: 0 auto;
      text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }
    
    .login-left-content .features {
      margin-top: 30px;
      text-align: left;
      max-width: 350px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .login-left-content .features .feature-item {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
      background: rgba(0,0,0,0.35);
      padding: 10px 16px;
      border-radius: 12px;
      backdrop-filter: blur(5px);
    }
    
    .login-left-content .features .feature-item i {
      width: 24px;
      color: #F9A825;
      font-size: 1.1rem;
    }
    
    .login-left-content .features .feature-item span {
      font-size: 0.95rem;
      text-shadow: 0 1px 4px rgba(0,0,0,0.3);
    }
    
    /* Right Side - Login Form */
    .login-right {
      flex: 0 0 480px;
      padding: 50px 40px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: white;
      min-height: 500px;
    }
    
    .login-right .form-header {
      margin-bottom: 30px;
    }
    
    .login-right .form-title {
      font-size: 2rem;
      font-weight: 800;
      color: #1B5E20;
      margin-bottom: 4px;
    }
    
    .login-right .form-subtitle {
      color: #888;
      font-size: 0.95rem;
    }
    
    .login-right .form-group {
      margin-bottom: 16px;
    }
    
    .login-right .form-group label {
      font-weight: 600;
      font-size: 0.9rem;
      color: #333;
      margin-bottom: 6px;
      display: block;
    }
    
    .login-right .form-control {
      border-radius: 12px;
      padding: 12px 16px;
      border: 2px solid #e8ecef;
      transition: all 0.3s ease;
      font-size: 0.95rem;
      background: #f8fafb;
    }
    
    .login-right .form-control:focus {
      border-color: #2E7D32;
      box-shadow: 0 0 0 4px rgba(46,125,50,0.08);
      background: white;
    }
    
    .login-right .input-group .form-control {
      border-left: none;
      border-radius: 0 12px 12px 0;
    }
    
    .login-right .input-group-text {
      background: #f8fafb;
      border: 2px solid #e8ecef;
      border-right: none;
      border-radius: 12px 0 0 12px;
      color: #888;
    }
    
    .login-right .input-group:focus-within .input-group-text {
      border-color: #2E7D32;
      background: white;
    }
    
    .login-right .form-options {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 18px 0 22px;
    }
    
    .login-right .form-options .form-check {
      margin: 0;
    }
    
    .login-right .form-options .form-check-input {
      border-radius: 4px;
      border: 2px solid #d0d5dd;
    }
    
    .login-right .form-options .form-check-input:checked {
      background-color: #2E7D32;
      border-color: #2E7D32;
    }
    
    .login-right .form-options .form-check-label {
      font-size: 0.9rem;
      color: #555;
    }
    
    .login-right .form-options a {
      color: #2E7D32;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
    }
    
    .login-right .form-options a:hover {
      text-decoration: underline;
    }
    
    .login-right .btn-login {
      background: #2E7D32;
      color: white;
      padding: 14px;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1rem;
      border: none;
      transition: all 0.3s ease;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    
    .login-right .btn-login:hover {
      background: #1B5E20;
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(46,125,50,0.25);
    }
    
    .login-right .btn-login i {
      font-size: 1.1rem;
    }
    
    .login-right .register-link {
      text-align: center;
      margin-top: 20px;
      font-size: 0.95rem;
      color: #666;
    }
    
    .login-right .register-link a {
      color: #2E7D32;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
    }
    
    .login-right .register-link a:hover {
      text-decoration: underline;
    }
    
    /* Register Form */
    .login-right .register-form {
      display: none;
    }
    
    .login-right .register-form.active {
      display: block;
    }
    
    .login-right .login-form.hidden {
      display: none;
    }
    
    /* Social Login */
    .login-right .social-login {
      margin-top: 24px;
      text-align: center;
    }
    
    .login-right .social-login .divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }
    
    .login-right .social-login .divider::before,
    .login-right .social-login .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e8ecef;
    }
    
    .login-right .social-login .divider span {
      color: #999;
      font-size: 0.85rem;
    }
    
    .login-right .social-login .social-buttons {
      display: flex;
      gap: 12px;
      justify-content: center;
    }
    
    .login-right .social-login .social-buttons button {
      flex: 1;
      padding: 10px;
      border-radius: 12px;
      border: 2px solid #e8ecef;
      background: white;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 0.9rem;
      color: #555;
      cursor: pointer;
    }
    
    .login-right .social-login .social-buttons button:hover {
      border-color: #2E7D32;
      color: #2E7D32;
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    
    .login-right .social-login .social-buttons button.google:hover {
      color: #DB4437;
      border-color: #DB4437;
    }
    
    .login-right .social-login .social-buttons button.facebook:hover {
      color: #1877F2;
      border-color: #1877F2;
    }
    
    /* Alert messages */
    .alert {
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 0.9rem;
      border: none;
    }
    
    .alert-danger {
      background: #fde8e8;
      color: #c62828;
    }
    
    .alert-success {
      background: #e8f5e9;
      color: #2E7D32;
    }
    
    /* Responsive */
    @media (max-width: 992px) {
      .login-wrapper {
        flex-direction: column;
        max-width: 500px;
        min-height: auto;
      }
      
      .login-left {
        min-height: 250px;
        border-radius: 24px 24px 0 0;
      }
      
      .login-left-content {
        padding: 30px;
      }
      
      .login-left-content h2 {
        font-size: 1.8rem;
      }
      
      .login-left-content .features {
        display: none;
      }
      
      .login-right {
        flex: 1;
        padding: 30px 24px;
        min-height: auto;
      }
      
      .login-right .form-title {
        font-size: 1.6rem;
      }
    }
    
    @media (max-width: 576px) {
      .login-wrapper {
        border-radius: 16px;
      }
      
      .login-left {
        min-height: 200px;
      }
      
      .login-left-content {
        padding: 20px;
      }
      
      .login-left-content h2 {
        font-size: 1.4rem;
      }
      
      .login-left-content p {
        font-size: 0.9rem;
      }
      
      .login-right {
        padding: 24px 16px;
      }
      
      .login-right .form-title {
        font-size: 1.4rem;
      }
      
      .login-right .form-control {
        padding: 10px 14px;
        font-size: 0.9rem;
      }
      
      .login-right .btn-login {
        padding: 12px;
        font-size: 0.95rem;
      }
      
      .login-right .social-login .social-buttons {
        flex-wrap: wrap;
      }
      
      .login-right .social-login .social-buttons button {
        flex: 0 0 calc(50% - 6px);
        font-size: 0.85rem;
        padding: 8px;
      }
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="login-wrapper">
      <!-- Left Side - Image without gradient overlay -->
      <div class="login-left">
        <div class="login-left-content">
          <span class="brand-icon">
            <i class="fas fa-leaf"></i>
          </span>
          <h2>Welcome Back!</h2>
          <p>Your journey to fresh, organic produce starts here</p>
          <div class="features">
            <div class="feature-item">
              <i class="fas fa-check-circle"></i>
              <span>Fresh organic produce</span>
            </div>
            <div class="feature-item">
              <i class="fas fa-check-circle"></i>
              <span>Direct from farmers</span>
            </div>
            <div class="feature-item">
              <i class="fas fa-check-circle"></i>
              <span>Fast delivery to your door</span>
            </div>
            <div class="feature-item">
              <i class="fas fa-check-circle"></i>
              <span>Secure payments</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right Side - Login Form -->
      <div class="login-right">
        <!-- Login Form -->
        <div id="loginForm" class="login-form">
          <div class="form-header">
            <div class="form-title">Sign In</div>
            <div class="form-subtitle">Enter your credentials to continue</div>
          </div>
          
          <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show">
              <i class="fas fa-exclamation-circle me-2"></i><%= error %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% } %>
          
          <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show">
              <i class="fas fa-check-circle me-2"></i><%= success %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% } %>
          
          <form action="/auth/login" method="POST">
            <div class="form-group">
              <label for="email">Email Address</label>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <input type="email" class="form-control" id="email" name="email" required placeholder="you@example.com">
              </div>
            </div>
            
            <div class="form-group">
              <label for="password">Password</label>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                <input type="password" class="form-control" id="password" name="password" required placeholder="Enter your password">
              </div>
            </div>
            
            <div class="form-options">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" id="remember" name="remember">
                <label class="form-check-label" for="remember">Remember me</label>
              </div>
              <a href="/auth/forgot-password">Forgot password?</a>
            </div>
            
            <button type="submit" class="btn-login">
              <i class="fas fa-sign-in-alt"></i>
              Sign In
            </button>
          </form>
          
          <div class="register-link">
            Don't have an account? 
            <a onclick="showRegister()">Create Account</a>
          </div>
          
          <div class="social-login">
            <div class="divider">
              <span>or continue with</span>
            </div>
            <div class="social-buttons">
              <button class="google" onclick="alert('Google login coming soon!')">
                <i class="fab fa-google"></i> Google
              </button>
              <button class="facebook" onclick="alert('Facebook login coming soon!')">
                <i class="fab fa-facebook-f"></i> Facebook
              </button>
            </div>
          </div>
        </div>
        
        <!-- Register Form -->
        <div id="registerForm" class="register-form">
          <div class="form-header">
            <div class="form-title">Create Account</div>
            <div class="form-subtitle">Join the Verdant Fields community</div>
          </div>
          
          <form action="/auth/register" method="POST">
            <div class="row">
              <div class="col-6">
                <div class="form-group">
                  <label for="first_name">First Name</label>
                  <input type="text" class="form-control" id="first_name" name="first_name" required placeholder="John">
                </div>
              </div>
              <div class="col-6">
                <div class="form-group">
                  <label for="last_name">Last Name</label>
                  <input type="text" class="form-control" id="last_name" name="last_name" required placeholder="Doe">
                </div>
              </div>
            </div>
            
            <div class="form-group">
              <label for="reg_email">Email Address</label>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                <input type="email" class="form-control" id="reg_email" name="email" required placeholder="you@example.com">
              </div>
            </div>
            
            <div class="form-group">
              <label for="reg_phone">Phone Number</label>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                <input type="tel" class="form-control" id="reg_phone" name="phone" placeholder="+1 234 567 8900">
              </div>
            </div>
            
            <div class="form-group">
              <label for="reg_role">I want to join as</label>
              <select class="form-control" id="reg_role" name="role" style="appearance: auto; padding: 12px 16px;">
                <option value="customer">Customer</option>
                <option value="farmer">Farmer</option>
                <option value="buyer">Buyer</option>
                <option value="delivery_rider">Delivery Rider</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="reg_password">Password</label>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                <input type="password" class="form-control" id="reg_password" name="password" required minlength="6" placeholder="Min 6 characters">
              </div>
            </div>
            
            <div class="form-group">
              <label for="reg_confirm_password">Confirm Password</label>
              <div class="input-group">
                <span class="input-group-text"><i class="fas fa-check"></i></span>
                <input type="password" class="form-control" id="reg_confirm_password" name="confirm_password" required placeholder="Confirm password">
              </div>
            </div>
            
            <button type="submit" class="btn-login">
              <i class="fas fa-user-plus"></i>
              Create Account
            </button>
          </form>
          
          <div class="register-link">
            Already have an account? 
            <a onclick="showLogin()">Sign In</a>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function showRegister() {
      document.getElementById('loginForm').classList.add('hidden');
      document.getElementById('registerForm').classList.add('active');
    }
    
    function showLogin() {
      document.getElementById('loginForm').classList.remove('hidden');
      document.getElementById('registerForm').classList.remove('active');
    }
  </script>
</body>
</html>
